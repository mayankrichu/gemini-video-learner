# Application
ENVIRONMENT=development
LOG_LEVEL=INFO
PUBLIC_BASE_URL=http://localhost:8000

# Chrome extension CORS. Use comma-separated exact origins.
# Example after loading the extension: chrome-extension://abcdefghijklmnopabcdefghijklmnop
ALLOWED_ORIGINS=
# Keep empty in production. For local development only, an optional regex can be used.
ALLOWED_ORIGIN_REGEX=
FREE_RATE_LIMIT=30/minute
AI_RATE_LIMIT=6/minute

# Supabase (publishable key may be public; secret key is server-only)
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_REPLACE_ME
SUPABASE_SECRET_KEY=sb_secret_REPLACE_ME
SUPABASE_REQUEST_TIMEOUT_SECONDS=20

# Azure Blob dictionaries
AZURE_STORAGE_ACCOUNT_NAME=nakshavastorageaccount
AZURE_BLOB_CONTAINER_NAME=vocab-data
# Optional alternative to Managed Identity; keep blank when using Managed Identity.
AZURE_STORAGE_CONNECTION_STRING=
# Optional local directory containing verb_translations.json, noun_translations.json,
# and connector_translations.json. Useful for local development.
LOCAL_DICTIONARY_DIR=

# OpenAI (server-only)
OPENAI_API_KEY=sk-REPLACE_ME
OPENAI_MODEL=gpt-5-mini
OPENAI_PROMPT_VERSION=v1
OPENAI_TIMEOUT_SECONDS=75
OPENAI_MAX_RETRIES=1
OPENAI_BATCH_SIZE=50
OPENAI_CONCURRENCY=3
# Verify these rates against the model pricing page before production deployment.
OPENAI_INPUT_USD_PER_MILLION=0.25
OPENAI_CACHED_INPUT_USD_PER_MILLION=0.025
OPENAI_OUTPUT_USD_PER_MILLION=2.00
# Accounting/display conversion only. Actual token cost remains stored in USD.
OPENAI_USD_TO_EUR_RATE=1.00

# Stripe (server-only)
STRIPE_SECRET_KEY=sk_test_REPLACE_ME
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME
STRIPE_PRICE_100_MIN=price_REPLACE_ME
STRIPE_PRICE_500_MIN=price_REPLACE_ME
STRIPE_PRICE_1000_MIN=price_REPLACE_ME
STRIPE_AUTOMATIC_TAX=false
CREDIT_EXPIRATION_DAYS=365

# Owner/development controls
ADMIN_EMAIL=m.singh@hufschmied.net
ENABLE_DEV_CREDIT_ENDPOINT=false

# Guardrails
# This is a per-video synchronous processing limit, not the purchased balance.
MAX_VIDEO_MINUTES=180
MAX_TRANSCRIPT_BLOCKS=25000
MAX_TRANSCRIPT_CHARACTERS=1500000
MAX_AI_CANDIDATES=300
RESERVATION_TTL_MINUTES=60
ENTITLEMENT_STALE_MINUTES=75
